#!/usr/bin/env bash
#
# sprout - scaffold a ready-to-run project and open it in your editor.
#
# Usage: sprout <project-name> [language]
#
#   <project-name>  Name of the folder to create (required).
#   [language]      Language code to generate a starter template (optional).
#                   Without it, only the folder is created.
#
# Configuration (environment variables):
#   SPROUT_PROJECTS_DIR   Base directory for new projects.
#                       Default: the current OS Desktop (e.g. ~/Desktop)
#   SPROUT_EDITOR         Command used to open the project.
#                       Default: code   (set to "none" to skip opening)
#   SPROUT_NO_GIT         Set to 1 to skip creating a git repo + .gitignore.
#
# Supported languages (see the full list with: sprout --langs):
#   py js ts c cpp java go rs rb sh html php swift kt cs dart scala pl lua r
#   jl hs ex erl clj groovy m fs pas f90 nim cr zig v d ml rkt scm lisp tcl
#   sql ps1 bat sol elm coffee vb

set -euo pipefail

SPROUT_VERSION="2.1.0"
SPROUT_REPO="https://github.com/tanodev0/sprout"

# Resolve the user's Desktop. On Linux, honor the XDG localized folder name.
default_desktop() {
  if command -v xdg-user-dir >/dev/null 2>&1; then
    local d; d="$(xdg-user-dir DESKTOP 2>/dev/null || true)"
    if [ -n "$d" ] && [ "$d" != "$HOME" ]; then
      printf '%s' "$d"; return
    fi
  fi
  printf '%s' "$HOME/Desktop"
}

PROJECTS_DIR="${SPROUT_PROJECTS_DIR:-$(default_desktop)}"
EDITOR_CMD="${SPROUT_EDITOR:-code}"

SUPPORTED_LANGS="py js ts c cpp java go rs rb sh html php swift kt cs dart scala pl lua r jl hs ex erl clj groovy m fs pas f90 nim cr zig v d ml rkt scm lisp tcl sql ps1 bat sol elm coffee vb"

usage() {
  cat <<EOF
sprout $SPROUT_VERSION - grow a new project

Usage: sprout <project-name> [language]

Options:
  -h, --help     Show this help.
  --langs        List supported language codes.
  --version      Show the version.

Environment:
  SPROUT_PROJECTS_DIR  Base directory (default: your Desktop)
  SPROUT_EDITOR        Editor command (default: code; "none" to skip)
  SPROUT_NO_GIT        Set to 1 to skip git init + .gitignore

Examples:
  sprout my-api py
  sprout landing html
  sprout just-a-folder
EOF
}

case "${1:-}" in
  -h|--help)  usage; exit 0 ;;
  --version)  echo "sprout $SPROUT_VERSION"; exit 0 ;;
  --langs)    echo "$SUPPORTED_LANGS"; exit 0 ;;
esac

# Require a project name.
if [ "$#" -lt 1 ] || [ -z "${1// }" ]; then
  echo "Error: you must provide a project name." >&2
  echo "Usage: sprout <project-name> [language]" >&2
  exit 1
fi

NAME="$1"
DEST="$PROJECTS_DIR/$NAME"

# Create the project folder (and the base dir if missing).
if [ -d "$DEST" ]; then
  echo "Note: folder '$DEST' already exists. Opening it as-is." >&2
else
  mkdir -p "$DEST"
  echo "Created folder: $DEST"
fi

# Write a per-project README with run instructions.
write_readme() {
  local dir="$1" lang="$2" run_hint="$3"
  cat > "$dir/README.md" <<EOF
# $NAME

> Generated with [sprout]($SPROUT_REPO) — scaffolds a ready-to-run project and opens it in your editor.

**Language template:** \`$lang\`

## Run

\`\`\`sh
$run_hint
\`\`\`

> The exact toolchain (compiler/interpreter) must be installed on your system.
EOF
}

# Write a .gitignore: a base block plus a language-specific block.
write_gitignore() {
  local dir="$1" lang="$2" family=""
  lang="$(printf '%s' "$lang" | tr '[:upper:]' '[:lower:]')"
  case "$lang" in
    js|ts|javascript|typescript|node|nodejs) family="node" ;;
    py|python) family="python" ;;
    rs|rust) family="rust" ;;
    go|golang) family="go" ;;
    java|kt|kotlin|scala|groovy) family="jvm" ;;
    cs|csharp|fs|fsharp|vb|dotnet) family="dotnet" ;;
    c|cpp|c++|m|objc) family="c" ;;
    swift) family="swift" ;;
  esac

  {
    printf '# OS\n.DS_Store\nThumbs.db\n\n# Editor\n.idea/\n.vscode/\n*.swp\n'
    case "$family" in
      node)   printf '\n# Node\nnode_modules/\ndist/\nnpm-debug.log*\n.env\n' ;;
      python) printf '\n# Python\n__pycache__/\n*.py[cod]\n.venv/\nvenv/\n*.egg-info/\n.pytest_cache/\nbuild/\ndist/\n' ;;
      rust)   printf '\n# Rust\n/target/\n' ;;
      go)     printf '\n# Go\n*.exe\n*.test\n*.out\nbin/\n' ;;
      jvm)    printf '\n# JVM\n*.class\n*.jar\ntarget/\nbuild/\n.gradle/\n' ;;
      dotnet) printf '\n# .NET\nbin/\nobj/\n' ;;
      c)      printf '\n# C/C++\n*.o\n*.obj\n*.out\n*.exe\napp\na.out\n' ;;
      swift)  printf '\n# Swift\n.build/\n*.o\n' ;;
    esac
  } > "$dir/.gitignore"
}

# Initialize a git repo (unless disabled, git is missing, or already inside one).
init_git() {
  local dir="$1" lang="$2"
  [ "${SPROUT_NO_GIT:-}" = "1" ] && return 0
  if ! command -v git >/dev/null 2>&1; then
    echo "Note: git not found; skipping repository init." >&2
    return 0
  fi
  if git -C "$dir" rev-parse --is-inside-work-tree >/dev/null 2>&1; then
    echo "Note: already inside a git repository; skipping git init." >&2
    return 0
  fi
  git -C "$dir" init -q
  write_gitignore "$dir" "$lang"
  echo "Initialized git repository with .gitignore"
}

# Generate template files for a language code.
generate_template() {
  local lang="$1"
  local dir="$2"
  local run_hint=""

  # Normalize to lowercase and map common aliases.
  lang="$(printf '%s' "$lang" | tr '[:upper:]' '[:lower:]')"
  case "$lang" in
    python) lang="py" ;;
    javascript|node|nodejs) lang="js" ;;
    typescript) lang="ts" ;;
    c++) lang="cpp" ;;
    golang) lang="go" ;;
    rust) lang="rs" ;;
    ruby) lang="rb" ;;
    bash|shell|zsh) lang="sh" ;;
    kotlin) lang="kt" ;;
    csharp|c#|dotnet) lang="cs" ;;
    fsharp|f#) lang="fs" ;;
    perl) lang="pl" ;;
