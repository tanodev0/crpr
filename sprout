    objc|objective-c|objectivec) lang="m" ;;
    pascal) lang="pas" ;;
    fortran) lang="f90" ;;
    crystal) lang="cr" ;;
    vlang) lang="v" ;;
    ocaml) lang="ml" ;;
    racket) lang="rkt" ;;
